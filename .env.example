# Required: Neon Postgres connection string (unpooled — direct connection)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Required: shared secret for Vercel Cron auth.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In production, set on Vercel project Settings → Environment Variables for all environments.
# Vercel Cron sends "Authorization: Bearer <CRON_SECRET>" to your /api/cron/* routes.
CRON_SECRET="replace-me-with-32-bytes-hex"
